# Copy this file to .env.local and fill in values from your Supabase project
# (Project Settings -> API). Only the public anon key belongs in the client.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Web Push (VAPID) public key — safe to expose in the client. Generate a pair
# with `npx web-push generate-vapid-keys`; the private key goes in app_secrets
# (see migration 0025), never here.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
