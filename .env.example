# Copy this file to .env.local and fill in values from your Supabase project
# (Project Settings -> API). Only the public anon key belongs in the client.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Telegram bot @username, without the '@'. Only used to build the t.me deep link
# that connects a chat to a ledger; it is public by nature (it's how anyone finds
# the bot). The bot TOKEN is a secret and lives in Supabase secrets, never here.
VITE_TELEGRAM_BOT_USERNAME=TracrBot

# Web Push (VAPID) public key — safe to expose in the client. Generate a pair
# with `npx web-push generate-vapid-keys`; the private key goes in app_secrets
# (see migration 0025), never here.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Midtrans Snap client key — safe to expose in the client (same trust level
# as the VAPID public key above). Leave unset and the Billing page's top-up
# buttons stay "coming soon" automatically — no code change needed to enable
# once you have real keys. The SECRET server key goes in Supabase secrets
# (`supabase secrets set MIDTRANS_SERVER_KEY=...`), never here. Get sandbox
# keys at https://dashboard.midtrans.com (Settings -> Access keys).
VITE_MIDTRANS_CLIENT_KEY=
# Set to 'true' only once you swap in production (non-sandbox) Midtrans keys.
VITE_MIDTRANS_IS_PRODUCTION=false
